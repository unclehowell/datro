
.square-003-003 {
    float: left;
    position: relative;
    width: 16%;
    padding-bottom: 16%;
    background:#2c2c2c;
    margin: 1.66%;
    overflow: hidden;
    border-radius: 0.5em;
    border-width: 1px;
    border-style: solid;
    border-color: white;
    border-image: initial;
}

.square-003-003:hover {
    background-color: #303030;
}

.content-003-003 {
    position: absolute;
    height: 90%;
    width: 90%;
    padding: 5%;
}

.table-003-003 {
    display: table;
    width: 100%;
    height: 100%;
}

.table-cell-003-003 {
    display: table-cell;
    vertical-align: top;
}

.content-003-003 .rs-003-003 {
width: 100%;
    margin-top: 10px;
    max-width: 57%;
    min-height: 44%;
    image-rendering: auto;
    position: absolute;
    left: 12%;
    zoom: 1;
    margin-left: 11%;
}

@media screen and (max-width: 900px) {
.square-003-003 {
    min-width: 25vw;
    min-height: 16vw;
    line-height: 8vw;
}
}
